package com.kodewala.abs1;

abstract class Product {

	String itemName;
	double price;

	Product(String itemName, double price) {
		this.itemName = itemName;
		this.price = price;
	}

	abstract double calculator();

	String productDisplay() {
		return itemName;
	}
}

// Electronic Class
class Electronic extends Product {

	Electronic(String itemName, double price) {
		super(itemName, price);
	}

	@Override
	double calculator() {
		return price + (price * 0.18); // 18% GST
	}
}

// Grocery Class
class Grocery extends Product {

	Grocery(String itemName, double price) {
		super(itemName, price);
	}

	@Override
	double calculator() {
		return price + (price * 0.18); // 5% GST
	}
}

public class Driver1 {

	public static void main(String[] args) {

		Product ep = new Electronic("Induction", 1000);
		System.out.println("Item Name: " + ep.productDisplay() + " and price is: " + ep.calculator());

		Product gp = new Grocery("Wheat", 2000);
		System.out.println("Item Name: " + gp.productDisplay() + " and price is: " + gp.calculator());
	}
}