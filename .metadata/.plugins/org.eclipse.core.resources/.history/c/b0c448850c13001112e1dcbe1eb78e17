package codingpractics;

import java.util.HashSet;
import java.util.Set;

public class Code13 {
	
	public static void main(String[] args) {
		int[] arr =  {1,3,5,7,8,5,3,2,1,5,7,8,9,5,4,5};
		
		
		Set<Integer> set = new HashSet<>();
		
		for(int num: arr) {
			
			set.add(num);
			System.out.println("give me only unique value:"+ set);
			
		}
	}

}
