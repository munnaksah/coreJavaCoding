package com.kodewala.abs1;

abstract class Product {
	String itemName;
	double price;
	
	
	Product (String itemName,double price){
		this.itemName = itemName;
		this.price  = price;
		
	}
	 abstract double calculator();
	 
	 
	 String productDisplay() {
		 return itemName;
	 }



	}





class Electronic extends Product {

	Electronic(String itemName, double price) {
		super(itemName, price);
	}

	@Override
	double calculator() {
		return price + (price * 0.18);
	}

	

	

}

class Grocery extends Product {

	Grocery(String itemName, double price) {
		super(itemName, price);
	}

	@Override
	double calculator() {
		return  price + (price * 0.18);
	}


}

